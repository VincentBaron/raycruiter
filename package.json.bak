{
  "$schema": "https://www.raycast.com/downloads/extension.schema.json",
  "name": "raycast-recruiter-agent",
  "title": "Raycruiter Agent",
  "description": "Recruiter Agent for Raycast",
  "icon": "command-icon.png",
  "author": "vincentbaron",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "raycruiter-menu",
      "title": "Raycruiter Menu",
      "subtitle": "Raycruiter",
      "description": "Access Raycruiter Menu",
      "mode": "view"
    },
    {
      "name": "power-dialer",
      "title": "Power Dialer",
      "subtitle": "Raycruiter",
      "description": "Start the Power Dialer workflow",
      "mode": "view"
    },
    {
      "name": "search-databases",
      "title": "Search Databases",
      "subtitle": "Raycruiter",
      "description": "Search CRM databases",
      "mode": "view"
    },
    {
      "name": "configure-integrations",
      "title": "Configure Integrations",
      "subtitle": "Raycruiter",
      "description": "Configure ATS/CRM Integrations",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "type": "password",
      "required": false,
      "title": "API Key",
      "description": "API Key for AI Providers",
      "placeholder": "Enter API Key"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.11",
    "@raycast/utils": "^2.2.3",
    "openai": "^6.33.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.8",
    "@types/node": "20.8.10",
    "@types/react": "^19.2.14",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
